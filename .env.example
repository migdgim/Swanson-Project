# Copia in `.env` (che NON viene versionato) e compila i valori.

# --- NCBI E-utilities (ingest PubMed) ---
# Ottieni la key gratis: https://account.ncbi.nlm.nih.gov -> Account Settings -> API Key Management
NCBI_API_KEY=
NCBI_EMAIL=migdgim@gmail.com

# --- LLM per estrazione relazioni (fallback, S1) ---
ANTHROPIC_API_KEY=
# Modello scelto dopo la stima di costo su 100 abstract (S1)
LLM_MODEL=claude-haiku-4-5-20251001

# --- UMLS / SemMedDB (opzionale, quando la licenza è disponibile) ---
UMLS_API_KEY=

# --- Supabase (layer di pubblicazione, S4) ---
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
